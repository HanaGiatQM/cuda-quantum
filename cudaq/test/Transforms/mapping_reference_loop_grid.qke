// CHECK-LABEL: func.func @reference_nested_split_range_grid()
// CHECK-SAME: mapping_reorder_idx = [0, 1, 2, 3, 4, 5, 6, 7]
// CHECK-SAME: mapping_v2p = [0, 1, 2, 3, 4, 5, 6, 7]
// CHECK: %[[SPLIT_Q:.*]] = quake.alloca !quake.veq<8>
// CHECK-NOT: cc.loop while
// CHECK: %[[SPLIT_Q0:.*]] = quake.extract_ref %[[SPLIT_Q]][0] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: %[[SPLIT_Q2:.*]] = quake.extract_ref %[[SPLIT_Q]][2] : (!quake.veq<8>) -> !quake.ref
