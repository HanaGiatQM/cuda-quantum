// CHECK-NEXT: %[[SPLIT_Q3:.*]] = quake.extract_ref %[[SPLIT_Q]][3] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: %[[SPLIT_Q1_PATH_2:.*]] = quake.extract_ref %[[SPLIT_Q]][1] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: %[[SPLIT_Q2_PATH:.*]] = quake.extract_ref %[[SPLIT_Q]][2] : (!quake.veq<8>) -> !quake.ref
