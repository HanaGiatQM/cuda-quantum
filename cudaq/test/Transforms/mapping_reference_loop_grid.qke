// CHECK-NEXT: quake.swap %[[REVERSE_Q7]], %[[REVERSE_Q6]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: quake.swap %[[REVERSE_Q6]], %[[REVERSE_Q5]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: quake.swap %[[REVERSE_Q5]], %[[REVERSE_Q4]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: %[[REVERSE_Q2:.*]] = quake.extract_ref %[[REVERSE_Q]][2] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: %[[REVERSE_Q3_NEXT:.*]] = quake.extract_ref %[[REVERSE_Q]][3] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: quake.x {{\[}}%[[REVERSE_Q2]]] %[[REVERSE_Q3_NEXT]] : (!quake.ref, !quake.ref) -> ()
