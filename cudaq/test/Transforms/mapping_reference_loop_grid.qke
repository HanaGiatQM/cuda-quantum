// RUN: cudaq-opt --pass-pipeline='builtin.module(func.func(memtoreg{quantum=0},canonicalize,cc-loop-normalize,canonicalize,memtoreg,canonicalize),add-wireset,func.func(assign-wire-indices),qubit-mapping{device=grid(4,2) raise-fatal-errors=true},func.func(regtomem,canonicalize))' %s | FileCheck %s

module {
  func.func @reference_nested_ghz_grid() attributes {"cudaq-entrypoint", "cudaq-kernel"} {
    %c1_i32 = arith.constant 1 : i32
    %c0_i32 = arith.constant 0 : i32
    %c2_i32 = arith.constant 2 : i32
    %c7_i32 = arith.constant 7 : i32
    %q = quake.alloca !quake.veq<8>
    %q0 = quake.extract_ref %q[0] : (!quake.veq<8>) -> !quake.ref
    quake.h %q0 : (!quake.ref) -> ()
    cc.loop while ((%pass = %c0_i32) -> (i32)) {
      %again = arith.cmpi slt, %pass, %c2_i32 : i32
      cc.condition %again(%pass : i32)
    } do {
    ^bb0(%pass: i32):
      cc.loop while ((%i = %c0_i32) -> (i32)) {
        %keep_going = arith.cmpi slt, %i, %c7_i32 : i32
        cc.condition %keep_going(%i : i32)
      } do {
      ^bb0(%i: i32):
        %ctrl_idx = cc.cast signed %i : (i32) -> i64
        %target_i32 = arith.addi %i, %c1_i32 : i32
        %target_idx = cc.cast signed %target_i32 : (i32) -> i64
        %ctrl_ref = quake.extract_ref %q[%ctrl_idx] : (!quake.veq<8>, i64) -> !quake.ref
        %target_ref = quake.extract_ref %q[%target_idx] : (!quake.veq<8>, i64) -> !quake.ref
        %ctrl = quake.unwrap %ctrl_ref : (!quake.ref) -> !quake.wire
        %target = quake.unwrap %target_ref : (!quake.ref) -> !quake.wire
        %next:2 = quake.x [%ctrl] %target : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
        quake.wrap %next#0 to %ctrl_ref : !quake.wire, !quake.ref
        quake.wrap %next#1 to %target_ref : !quake.wire, !quake.ref
        cc.continue %i : i32
      } step {
      ^bb0(%i: i32):
        %next = arith.addi %i, %c1_i32 : i32
        cc.continue %next : i32
      }
      cc.continue %pass : i32
    } step {
    ^bb0(%pass: i32):
      %next = arith.addi %pass, %c1_i32 : i32
      cc.continue %next : i32
    }
    %meas = quake.mz %q : (!quake.veq<8>) -> !cc.stdvec<!cc.measure_handle>
    return
  }

  func.func @reference_nested_offset_grid() attributes {"cudaq-entrypoint", "cudaq-kernel"} {
    %c1_i32 = arith.constant 1 : i32
    %c0_i32 = arith.constant 0 : i32
    %c2_i32 = arith.constant 2 : i32
    %c3_i32 = arith.constant 3 : i32
    %c5_i32 = arith.constant 5 : i32
    %q = quake.alloca !quake.veq<8>
    cc.loop while ((%pass = %c0_i32) -> (i32)) {
      %again = arith.cmpi slt, %pass, %c2_i32 : i32
      cc.condition %again(%pass : i32)
    } do {
    ^bb0(%pass: i32):
      cc.loop while ((%i = %c0_i32) -> (i32)) {
        %keep_going = arith.cmpi slt, %i, %c5_i32 : i32
        cc.condition %keep_going(%i : i32)
      } do {
      ^bb0(%i: i32):
        %ctrl_idx = cc.cast signed %i : (i32) -> i64
        %target_i32 = arith.addi %i, %c3_i32 : i32
        %target_idx = cc.cast signed %target_i32 : (i32) -> i64
        %ctrl_ref = quake.extract_ref %q[%ctrl_idx] : (!quake.veq<8>, i64) -> !quake.ref
        %target_ref = quake.extract_ref %q[%target_idx] : (!quake.veq<8>, i64) -> !quake.ref
        %ctrl = quake.unwrap %ctrl_ref : (!quake.ref) -> !quake.wire
        %target = quake.unwrap %target_ref : (!quake.ref) -> !quake.wire
        %next:2 = quake.x [%ctrl] %target : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
        quake.wrap %next#0 to %ctrl_ref : !quake.wire, !quake.ref
        quake.wrap %next#1 to %target_ref : !quake.wire, !quake.ref
        cc.continue %i : i32
      } step {
      ^bb0(%i: i32):
        %next = arith.addi %i, %c1_i32 : i32
        cc.continue %next : i32
      }
      cc.continue %pass : i32
    } step {
    ^bb0(%pass: i32):
      %next = arith.addi %pass, %c1_i32 : i32
      cc.continue %next : i32
    }
    %meas = quake.mz %q : (!quake.veq<8>) -> !cc.stdvec<!cc.measure_handle>
    return
  }

  func.func @reference_nested_reverse_index_grid() attributes {"cudaq-entrypoint", "cudaq-kernel"} {
    %c1_i32 = arith.constant 1 : i32
    %c0_i32 = arith.constant 0 : i32
    %c2_i32 = arith.constant 2 : i32
    %c3_i32 = arith.constant 3 : i32
    %c4_i32 = arith.constant 4 : i32
    %q = quake.alloca !quake.veq<8>
    cc.loop while ((%pass = %c0_i32) -> (i32)) {
      %again = arith.cmpi slt, %pass, %c2_i32 : i32
      cc.condition %again(%pass : i32)
    } do {
    ^bb0(%pass: i32):
      cc.loop while ((%i = %c0_i32) -> (i32)) {
        %keep_going = arith.cmpi slt, %i, %c3_i32 : i32
        cc.condition %keep_going(%i : i32)
      } do {
      ^bb0(%i: i32):
        %ctrl_i32 = arith.subi %c3_i32, %i : i32
        %ctrl_idx = cc.cast signed %ctrl_i32 : (i32) -> i64
        %target_i32 = arith.subi %c4_i32, %i : i32
        %target_idx = cc.cast signed %target_i32 : (i32) -> i64
        %ctrl_ref = quake.extract_ref %q[%ctrl_idx] : (!quake.veq<8>, i64) -> !quake.ref
        %target_ref = quake.extract_ref %q[%target_idx] : (!quake.veq<8>, i64) -> !quake.ref
        %ctrl = quake.unwrap %ctrl_ref : (!quake.ref) -> !quake.wire
        %target = quake.unwrap %target_ref : (!quake.ref) -> !quake.wire
        %next:2 = quake.x [%ctrl] %target : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
        quake.wrap %next#0 to %ctrl_ref : !quake.wire, !quake.ref
        quake.wrap %next#1 to %target_ref : !quake.wire, !quake.ref
        cc.continue %i : i32
      } step {
      ^bb0(%i: i32):
        %next = arith.addi %i, %c1_i32 : i32
        cc.continue %next : i32
      }
      cc.continue %pass : i32
    } step {
    ^bb0(%pass: i32):
      %next = arith.addi %pass, %c1_i32 : i32
      cc.continue %next : i32
    }
    %meas = quake.mz %q : (!quake.veq<8>) -> !cc.stdvec<!cc.measure_handle>
    return
  }

  func.func @reference_nested_split_range_grid() attributes {"cudaq-entrypoint", "cudaq-kernel"} {
    %c1_i32 = arith.constant 1 : i32
    %c0_i32 = arith.constant 0 : i32
    %c2_i32 = arith.constant 2 : i32
    %c5_i32 = arith.constant 5 : i32
    %q = quake.alloca !quake.veq<8>
    cc.loop while ((%i = %c0_i32) -> (i32)) {
      %keep_i = arith.cmpi slt, %i, %c2_i32 : i32
      cc.condition %keep_i(%i : i32)
    } do {
    ^bb0(%i: i32):
      cc.loop while ((%j = %c2_i32) -> (i32)) {
        %keep_j = arith.cmpi slt, %j, %c5_i32 : i32
        cc.condition %keep_j(%j : i32)
      } do {
      ^bb0(%j: i32):
        %ctrl_idx = cc.cast signed %i : (i32) -> i64
        %target_idx = cc.cast signed %j : (i32) -> i64
        %ctrl_ref = quake.extract_ref %q[%ctrl_idx] : (!quake.veq<8>, i64) -> !quake.ref
        %target_ref = quake.extract_ref %q[%target_idx] : (!quake.veq<8>, i64) -> !quake.ref
        %ctrl = quake.unwrap %ctrl_ref : (!quake.ref) -> !quake.wire
        %target = quake.unwrap %target_ref : (!quake.ref) -> !quake.wire
        %next:2 = quake.x [%ctrl] %target : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
        quake.wrap %next#0 to %ctrl_ref : !quake.wire, !quake.ref
        quake.wrap %next#1 to %target_ref : !quake.wire, !quake.ref
        cc.continue %j : i32
      } step {
      ^bb0(%j: i32):
        %next = arith.addi %j, %c1_i32 : i32
        cc.continue %next : i32
      }
      cc.continue %i : i32
    } step {
    ^bb0(%i: i32):
      %next = arith.addi %i, %c1_i32 : i32
      cc.continue %next : i32
    }
    %meas = quake.mz %q : (!quake.veq<8>) -> !cc.stdvec<!cc.measure_handle>
    return
  }
}

// CHECK-LABEL: func.func @reference_nested_ghz_grid()
// CHECK-SAME: mapping_reorder_idx = [0, 1, 2, 3, 4, 5, 6, 7]
// CHECK-SAME: mapping_v2p = [0, 1, 2, 3, 4, 5, 6, 7]
// CHECK: %[[Q:.*]] = quake.alloca !quake.veq<8>
// CHECK: cc.loop while
// CHECK: ^bb0(%[[PASS:.*]]: i32):
// CHECK-NOT: cc.loop while
// CHECK: %[[G_Q0:.*]] = quake.extract_ref %[[Q]][0] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: %[[G_Q1:.*]] = quake.extract_ref %[[Q]][1] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: quake.x {{\[}}%[[G_Q0]]] %[[G_Q1]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: %[[G_Q1_NEXT:.*]] = quake.extract_ref %[[Q]][1] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: %[[G_Q2:.*]] = quake.extract_ref %[[Q]][2] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: quake.x {{\[}}%[[G_Q1_NEXT]]] %[[G_Q2]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: %[[PREV_Q2:.*]] = quake.extract_ref %[[Q]][2] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: %[[PREV_Q3:.*]] = quake.extract_ref %[[Q]][3] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: quake.x {{\[}}%[[PREV_Q2]]] %[[PREV_Q3]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: %[[Q3:.*]] = quake.extract_ref %[[Q]][3] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: %[[Q4:.*]] = quake.extract_ref %[[Q]][4] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: %[[Q7:.*]] = quake.extract_ref %[[Q]][7] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: %[[Q6:.*]] = quake.extract_ref %[[Q]][6] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: %[[Q5:.*]] = quake.extract_ref %[[Q]][5] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: quake.swap %[[Q5]], %[[Q4]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: quake.swap %[[Q6]], %[[Q5]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: quake.swap %[[Q7]], %[[Q6]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: quake.x {{\[}}%[[Q3]]] %[[Q7]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: quake.swap %[[Q7]], %[[Q6]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: quake.swap %[[Q6]], %[[Q5]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: quake.swap %[[Q5]], %[[Q4]] : (!quake.ref, !quake.ref) -> ()
// CHECK: cc.continue %[[PASS]] : i32
// CHECK-NOT: quake.unwrap
// CHECK-NOT: quake.wrap
// CHECK: quake.mz %[[Q]] : (!quake.veq<8>) -> !cc.stdvec<!cc.measure_handle>
// CHECK: return

