// CHECK-NEXT: quake.x {{\[}}%[[SPLIT_Q0_NEXT]]] %[[SPLIT_Q1_PATH_2]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: quake.swap %[[SPLIT_Q1_PATH_2]], %[[SPLIT_Q2_PATH]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: quake.swap %[[SPLIT_Q2_PATH]], %[[SPLIT_Q3]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: %[[SPLIT_Q0_DIRECT:.*]] = quake.extract_ref %[[SPLIT_Q]][0] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: %[[SPLIT_Q4:.*]] = quake.extract_ref %[[SPLIT_Q]][4] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: quake.x {{\[}}%[[SPLIT_Q0_DIRECT]]] %[[SPLIT_Q4]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: %[[SPLIT_Q1:.*]] = quake.extract_ref %[[SPLIT_Q]][1] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: %[[SPLIT_Q2_DIRECT:.*]] = quake.extract_ref %[[SPLIT_Q]][2] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: quake.x {{\[}}%[[SPLIT_Q1]]] %[[SPLIT_Q2_DIRECT]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: %[[SPLIT_Q1_NEXT:.*]] = quake.extract_ref %[[SPLIT_Q]][1] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: %[[SPLIT_Q3_NEXT:.*]] = quake.extract_ref %[[SPLIT_Q]][3] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: %[[SPLIT_Q2_PATH_2:.*]] = quake.extract_ref %[[SPLIT_Q]][2] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: quake.swap %[[SPLIT_Q2_PATH_2]], %[[SPLIT_Q3_NEXT]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: quake.x {{\[}}%[[SPLIT_Q1_NEXT]]] %[[SPLIT_Q2_PATH_2]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: quake.swap %[[SPLIT_Q2_PATH_2]], %[[SPLIT_Q3_NEXT]] : (!quake.ref, !quake.ref) -> ()
// CHECK-NEXT: %[[SPLIT_Q1_LAST:.*]] = quake.extract_ref %[[SPLIT_Q]][1] : (!quake.veq<8>) -> !quake.ref
// CHECK-NEXT: %[[SPLIT_Q4_LAST:.*]] = quake.extract_ref %[[SPLIT_Q]][4] : (!quake.veq<8>) -> !quake.ref
